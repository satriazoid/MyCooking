<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cafe_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/cafe_primary"
        app:titleTextColor="@color/cafe_text_dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nama Menu -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutNama"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/label_nama"
                app:hintTextColor="@color/cafe_text_dark"
                app:boxStrokeColor="@color/cafe_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textColor="@color/cafe_text_dark"
                    android:textColorHint="@color/cafe_text_light" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Kategori -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_kategori"
                android:textSize="12sp"
                android:textColor="@color/cafe_text_dark"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerKategori"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_bg" />

            <!-- Bahan -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutBahan"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/label_bahan"
                app:hintTextColor="@color/cafe_text_dark"
                app:boxStrokeColor="@color/cafe_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editBahan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="@color/cafe_text_dark"
                    android:textColorHint="@color/cafe_text_light" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Harga -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutHarga"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/label_harga"
                app:prefixText="Rp "
                app:prefixTextColor="@color/cafe_text_dark"
                app:hintTextColor="@color/cafe_text_dark"
                app:boxStrokeColor="@color/cafe_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editHarga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/cafe_text_dark"
                    android:textColorHint="@color/cafe_text_light" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Rating -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_rating"
                android:textSize="12sp"
                android:textColor="@color/cafe_text_dark"
                android:layout_marginTop="16dp" />

            <RatingBar
                android:id="@+id/ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.5"
                android:rating="3.0"
                android:progressTint="@color/cafe_secondary" />

            <!-- Pilih Foto -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPilihFoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_pilih_foto"
                android:textColor="@color/cafe_secondary"
                app:strokeColor="@color/cafe_secondary"
                app:cornerRadius="12dp" />

            <!-- Simpan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_simpan"
                android:textColor="@color/white"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                app:backgroundTint="@color/cafe_secondary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
